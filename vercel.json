{
  "version": 2,
  "buildCommand": "npm install -g pnpm && pnpm install --frozen-lockfile=false && pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install -g pnpm && pnpm install --frozen-lockfile=false",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
